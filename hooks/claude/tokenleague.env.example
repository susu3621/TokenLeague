# TokenLeague Hook Configuration
# Copy this file to your shell profile or .env and fill in the values

# TokenLeague API URL (default: http://localhost:5006)
export TOKENLEAGUE_API_URL="http://localhost:5006"

# Your TokenLeague Hook Key (required)
# Get this from your TokenLeague user settings page
export TOKENLEAGUE_HOOK_KEY="your-hook-key-here"
