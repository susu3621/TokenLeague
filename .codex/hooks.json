{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/tokenleague.py",
            "timeoutSec": 10,
            "statusMessage": "tracking TokenLeague usage"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/tokenleague.py",
            "timeoutSec": 30
          }
        ]
      }
    ]
  }
}
